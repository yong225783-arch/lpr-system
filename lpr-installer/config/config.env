# 車牌辨識系統設定檔

# 攝影機設定
# 留空使用 USB webcam，填入 RTSP URL 使用 IP cam
CAMERA_IN_URL=
CAMERA_OUT_URL=

# 繼電器設定
# Windows: COM3, COM4 等
# Linux: /dev/ttyUSB0 等
RELAY_PORT=

# 開門信號持續時間（秒）
OPEN_DURATION=1.5

# 是否模擬繼電器（不用硬體時設為 1）
SIMULATE_RELAY=1

# Flask 設定
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
SECRET_KEY=lpr-secret-key-change-in-production

# OCR 設定
YOLO_CONF=0.5
OCR_CONF=0.3
IMAGE_ZOOM=2
COOLDOWN=5
OCR_ENGINE=easyocr
